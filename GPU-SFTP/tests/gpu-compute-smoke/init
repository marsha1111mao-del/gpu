#!/bin/sh

PATH=/usr/sbin:/usr/bin:/sbin:/bin
export PATH

mountpoint -q /proc || mount -t proc proc /proc
mountpoint -q /sys || mount -t sysfs sysfs /sys
mountpoint -q /dev || mount -t devtmpfs devtmpfs /dev

mkdir -p /dev/pts /dev/shm /run /tmp
mountpoint -q /dev/pts || mount -t devpts devpts /dev/pts
mountpoint -q /dev/shm || mount -t tmpfs tmpfs /dev/shm
mountpoint -q /run || mount -t tmpfs tmpfs /run
mountpoint -q /tmp || mount -t tmpfs tmpfs /tmp
chmod 1777 /tmp /dev/shm

hostname firecracker-gpu-smoke 2>/dev/null || true

echo "[init] starting GPU passthrough user-space smoke test"

cmdline_value() {
	key="$1"
	for word in $(cat /proc/cmdline 2>/dev/null); do
		case "${word}" in
		"${key}="*)
			printf '%s\n' "${word#*=}"
			return 0
			;;
		esac
	done
	return 1
}

decode_cmdline_arg_tokens() {
	rest="$1"
	out=""

	while :; do
		case "${rest}" in
		*:*)
			token="${rest%%:*}"
			rest="${rest#*:}"
			;;
		*)
			token="${rest}"
			rest=""
			;;
		esac

		if [ -n "${token}" ]; then
			if [ -n "${out}" ]; then
				out="${out} ${token}"
			else
				out="${token}"
			fi
		fi

		[ -n "${rest}" ] || break
	done

	printf '%s\n' "${out}"
}

apply_cmdline_overrides() {
	value="$(cmdline_value gpu_smoke_args_tokens || true)"
	if [ -n "${value}" ]; then
		GPU_SMOKE_ARGS="$(decode_cmdline_arg_tokens "${value}")"
		export GPU_SMOKE_ARGS
	fi

	value="$(cmdline_value gpu_smoke_args_b64 || true)"
	if [ -n "${value}" ]; then
		if ! command -v base64 >/dev/null 2>&1; then
			echo "[init] missing base64 for gpu_smoke_args_b64"
			return 1
		fi
		GPU_SMOKE_ARGS="$(printf '%s' "${value}" | base64 -d 2>/dev/null)" || {
			echo "[init] failed to decode gpu_smoke_args_b64"
			return 1
		}
		export GPU_SMOKE_ARGS
	fi

	value="$(cmdline_value gpu_smoke_quiet_console || true)"
	if [ -n "${value}" ]; then
		GPU_SMOKE_QUIET_CONSOLE="${value}"
		export GPU_SMOKE_QUIET_CONSOLE
	fi

	value="$(cmdline_value gpu_smoke_after_run || true)"
	if [ -n "${value}" ]; then
		GPU_SMOKE_AFTER_RUN="${value}"
		export GPU_SMOKE_AFTER_RUN
	fi
}

if [ -f /root/gpu-smoke.env ]; then
	# shellcheck disable=SC1091
	. /root/gpu-smoke.env
fi

if ! apply_cmdline_overrides; then
	echo "[init] GPU_SMOKE_RESULT=FAIL rc=125"
	exit 125
fi

/root/gpu-smoke.sh
rc=$?
if [ "${rc}" -eq 0 ]; then
	echo "[init] GPU_SMOKE_RESULT=PASS"
else
	echo "[init] GPU_SMOKE_RESULT=FAIL rc=${rc}"
fi

sync
case "${GPU_SMOKE_AFTER_RUN:-shell}" in
poweroff | halt)
	echo "[init] smoke test finished; powering off"
	poweroff -f 2>/dev/null || halt -f 2>/dev/null || exit "${rc}"
	;;
exit)
	echo "[init] smoke test finished; exiting init"
	exit "${rc}"
	;;
*)
	echo "[init] smoke test finished; entering shell"
	exec /bin/sh
	;;
esac
