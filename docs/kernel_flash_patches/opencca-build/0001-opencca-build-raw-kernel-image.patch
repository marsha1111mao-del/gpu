From 9af49955f609d93e15be496ce965c1fd43822904 Mon Sep 17 00:00:00 2001
From: xander <xanderc@qq.com>
Date: Fri, 29 May 2026 10:50:57 +0800
Subject: [PATCH] opencca: build raw kernel image

---
 buildconf/linux.mk | 97 +++++++++++++++++++++++++++++++++++++++++-----
 1 file changed, 87 insertions(+), 10 deletions(-)

diff --git a/buildconf/linux.mk b/buildconf/linux.mk
index 79404e4..a4f6270 100755
--- a/buildconf/linux.mk
+++ b/buildconf/linux.mk
@@ -13,6 +13,18 @@ build: kernel ## see kernel
 
 KERNEL_CONFIG := $(LINUX_DIR)/.config
 KERNEL_FRAGMENT := $(LINUX_DIR)/rk3588_fragment.config ## kconfig fragment
+KERNEL_IMAGE_REL := arch/arm64/boot/Image
+KERNEL_DTB_REL := arch/arm64/boot/dts/rockchip/rk3588-rock-5b.dtb
+KERNEL_IMAGE := $(LINUX_DIR)/$(KERNEL_IMAGE_REL)
+KERNEL_DTB := $(LINUX_DIR)/$(KERNEL_DTB_REL)
+KERNEL_SLOT_SECTORS ?= 262144 ## raw eMMC kernel slot size in 512-byte sectors
+KERNEL_SLOT_BYTES := $(shell echo $$(( $(KERNEL_SLOT_SECTORS) * 512 )))
+KERNEL_ITS := $(SNAPSHOT_DIR)/kernel.its
+KERNEL_ITB := $(SNAPSHOT_DIR)/kernel.itb
+KERNEL_IMG := $(SNAPSHOT_DIR)/kernel.img
+KERNEL_LOAD_ADDR ?= 0x12280000
+KERNEL_ENTRY_ADDR ?= 0x12280000
+MKIMAGE ?= $(shell command -v mkimage 2>/dev/null || echo $(UBOOT_DIR)/tools/mkimage)
 KERNEL_KCONFIG += \
 		-e WLAN \
 		-e WLAN_VENDOR_BROADCOM \
@@ -70,19 +82,84 @@ kconfig_old: $(KERNEL_FRAGMENT) ## Generate .config file
 	-cp -rf $(LINUX_DIR)/.config $(SNAPSHOT_DIR)/rk3588-kernel-config
 
 .PHONY: kernel
-kernel: kconfig ## build linux kernel
-	@echo "Building kernel"
-	+$(MAKE) -C $(LINUX_DIR) KBUILD_IMAGE="arch/arm64/boot/Image" \
-		LOCALVERSION=$(LOCALVERSION) 
+kernel: kconfig ## build linux kernel and raw Maskrom kernel image
+	+$(MAKE) -f $(firstword $(MAKEFILE_LIST)) kernel-image
 
-	-cp -rf $(LINUX_DIR)/arch/arm64/boot/Image $(SNAPSHOT_DIR)
+.PHONY: kernel-image
+kernel-image: $(KERNEL_IMG) ## build raw Maskrom kernel image without regenerating .config
 
-.PHONY: devel
-devel: ## Build kernel without re-generating .config first (devel)
-	+$(MAKE) -C $(LINUX_DIR) KBUILD_IMAGE=arch/arm64/boot/Image \
-		LOCALVERSION=$(LOCALVERSION) 
+.PHONY: build-kernel
+build-kernel:
+	@echo "Building kernel"
+	+$(MAKE) -C $(LINUX_DIR) KBUILD_IMAGE="$(KERNEL_IMAGE_REL)" \
+		LOCALVERSION=$(LOCALVERSION)
+	+$(MAKE) -C $(LINUX_DIR) ARCH=$(ARCH) LOCALVERSION=$(LOCALVERSION) dtbs
+
+$(KERNEL_ITS): build-kernel
+	mkdir -p $(SNAPSHOT_DIR)
+	cp -f $(KERNEL_IMAGE) $(SNAPSHOT_DIR)/Image
+	cp -f $(KERNEL_DTB) $(SNAPSHOT_DIR)/rk3588-rock-5b.dtb
+	{ \
+		echo '/dts-v1/;'; \
+		echo ''; \
+		echo '/ {'; \
+		echo '	description = "OpenCCA RK3588 kernel";'; \
+		echo '	#address-cells = <1>;'; \
+		echo ''; \
+		echo '	images {'; \
+		echo '		kernel {'; \
+		echo '			description = "Linux Image";'; \
+		echo '			data = /incbin/("Image");'; \
+		echo '			type = "kernel";'; \
+		echo '			arch = "arm64";'; \
+		echo '			os = "linux";'; \
+		echo '			compression = "none";'; \
+		echo '			load = <$(KERNEL_LOAD_ADDR)>;'; \
+		echo '			entry = <$(KERNEL_ENTRY_ADDR)>;'; \
+		echo '			hash {'; \
+		echo '				algo = "sha256";'; \
+		echo '			};'; \
+		echo '		};'; \
+		echo ''; \
+		echo '		fdt {'; \
+		echo '			description = "Rock 5B device tree";'; \
+		echo '			data = /incbin/("rk3588-rock-5b.dtb");'; \
+		echo '			type = "flat_dt";'; \
+		echo '			arch = "arm64";'; \
+		echo '			compression = "none";'; \
+		echo '			hash {'; \
+		echo '				algo = "sha256";'; \
+		echo '			};'; \
+		echo '		};'; \
+		echo '	};'; \
+		echo ''; \
+		echo '	configurations {'; \
+		echo '		default = "conf";'; \
+		echo '		conf {'; \
+		echo '			description = "OpenCCA RK3588";'; \
+		echo '			kernel = "kernel";'; \
+		echo '			fdt = "fdt";'; \
+		echo '		};'; \
+		echo '	};'; \
+		echo '};'; \
+	} > $(KERNEL_ITS)
+
+$(UBOOT_DIR)/tools/mkimage:
+	+$(MAKE) -C $(UBOOT_DIR) tools-only
+
+$(KERNEL_ITB): $(KERNEL_ITS) $(MKIMAGE)
+	cd $(SNAPSHOT_DIR) && $(MKIMAGE) -f $(notdir $(KERNEL_ITS)) $(notdir $(KERNEL_ITB))
+
+$(KERNEL_IMG): $(KERNEL_ITB)
+	@if [ "$$(stat -c%s $(KERNEL_ITB))" -gt "$(KERNEL_SLOT_BYTES)" ]; then \
+		echo "ERROR: $(KERNEL_ITB) exceeds kernel slot size $(KERNEL_SLOT_BYTES) bytes"; \
+		exit 1; \
+	fi
+	cp -f $(KERNEL_ITB) $(KERNEL_IMG)
+	truncate -s $(KERNEL_SLOT_BYTES) $(KERNEL_IMG)
 
-	-cp -rf $(LINUX_DIR)/arch/arm64/boot/Image $(SNAPSHOT_DIR)
+.PHONY: devel
+devel: kernel-image ## Build kernel without re-generating .config first (devel)
 
 
 # ---------------
-- 
