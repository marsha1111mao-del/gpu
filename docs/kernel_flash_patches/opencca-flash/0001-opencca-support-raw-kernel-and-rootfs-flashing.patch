+    fi
+
+    rm -rf "$gpt_tmpdir"
+}
+
+function require_mmc_rootfs_layout {
+    local rootfs_image=$1
+    local rootfs_bytes
+    local rootfs_sectors
+    local gpt_dump
+    local gpt_tmpdir
+
+    rootfs_bytes=$(stat -c%s "$rootfs_image")
+    rootfs_sectors=$(( (rootfs_bytes + 511) / 512 ))
+
+    gpt_tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/opencca-gpt.XXXXXX")
+    gpt_dump="$gpt_tmpdir/gpt.bin"
+    if ! $CMD rl 0 34 "$gpt_dump"; then
+        rm -rf "$gpt_tmpdir"
+        echo "Failed to read eMMC GPT; refusing to write rootfs" >&2
+        exit 1
+    fi
+
+    if ! python3 "$SCRIPT_DIR/validate_gpt_kernel_slot.py" \
+        "$gpt_dump" "$FLASH_MMC_ROOTFS_OFFSET" "$rootfs_sectors" \
+        --name root --required-bytes "$rootfs_bytes"
+    then
+        rm -rf "$gpt_tmpdir"
+        echo "eMMC layout is not compatible with mmc-rootfs; refusing to update rootfs" >&2
+        exit 1
+    fi
+
+    rm -rf "$gpt_tmpdir"
+}
+
