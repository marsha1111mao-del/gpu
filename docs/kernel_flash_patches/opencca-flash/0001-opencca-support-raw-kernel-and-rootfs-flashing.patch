index 0000000..914c58d
--- /dev/null
+++ b/convert_prebuilt_image.py
@@ -0,0 +1,249 @@
+#!/usr/bin/env python3
+import argparse
+import json
+import os
+import shutil
+import subprocess
+import sys
+import tempfile
+from pathlib import Path
+
+
+SECTOR_SIZE = 512
+LOADER1_START = 64
+LOADER1_SIZE = 7105
+LOADER2_START = 0x4000
+LOADER2_SIZE = 0x2000
+KERNEL_START = 0x8000
+KERNEL_SIZE = 0x40000
+ROOT_START = 0x48000
+LINUX_TYPE = "linux"
+EFI_TYPE = "uefi"
+
+
+def run(args: list[str], **kwargs) -> subprocess.CompletedProcess:
+    return subprocess.run(args, check=True, text=True, **kwargs)
+
+
+def require_tool(name: str) -> None:
+    if shutil.which(name) is None:
+        raise SystemExit(f"Missing required tool: {name}")
+
+
+def sectors_for_bytes(size: int) -> int:
+    return (size + SECTOR_SIZE - 1) // SECTOR_SIZE
+
+
+def image_sectors(path: Path) -> int:
+    size = path.stat().st_size
+    if size % SECTOR_SIZE:
+        raise SystemExit(f"{path} size is not sector aligned")
+    return size // SECTOR_SIZE
+
+
+def partition_table(path: Path) -> list[dict]:
+    result = run(["sfdisk", "--json", str(path)], stdout=subprocess.PIPE)
+    data = json.loads(result.stdout)
+    return data["partitiontable"]["partitions"]
+
+
+def find_partition(parts: list[dict], name: str) -> dict:
+    matches = [part for part in parts if part.get("name") == name]
+    if len(matches) != 1:
+        raise SystemExit(f"Expected exactly one {name!r} partition, found {len(matches)}")
+    return matches[0]
+
+
+def copy_range(src: Path, dst: Path, src_sector: int, dst_sector: int, sectors: int) -> None:
+    run(
+        [
+            "dd",
+            f"if={src}",
+            f"of={dst}",
+            f"bs={SECTOR_SIZE}",
+            f"skip={src_sector}",
+            f"seek={dst_sector}",
+            f"count={sectors}",
+            "conv=notrunc",
+            "status=none",
+        ]
+    )
+
+
+def extract_range(src: Path, dst: Path, start: int, sectors: int) -> None:
+    run(
+        [
+            "dd",
+            f"if={src}",
+            f"of={dst}",
+            f"bs={SECTOR_SIZE}",
+            f"skip={start}",
+            f"count={sectors}",
+            "status=none",
+        ]
+    )
+
+
+def write_file_to_sector(src: Path, dst: Path, dst_sector: int) -> None:
+    run(
+        [
+            "dd",
+            f"if={src}",
+            f"of={dst}",
+            f"bs={SECTOR_SIZE}",
+            f"seek={dst_sector}",
+            "conv=notrunc",
+            "status=none",
+        ]
+    )
+
+
+def shrink_ext4(rootfs: Path) -> None:
+    run(["e2fsck", "-fy", str(rootfs)])
+    run(["resize2fs", "-M", str(rootfs)])
+    run(["e2fsck", "-fy", str(rootfs)])
+
+
+def make_partition_table(out: Path, total_sectors: int, root_type: str) -> int:
+    root_size = total_sectors - ROOT_START - 34
+    if root_size <= 0:
+        raise SystemExit(f"Output image is too small for root start sector {ROOT_START:#x}")
+
+    table = (
+        "label: gpt\n"
+        "unit: sectors\n"
+        "first-lba: 34\n"
+        "sector-size: 512\n"
+        f"start={LOADER1_START}, size={LOADER1_SIZE}, type={LINUX_TYPE}, name=loader1\n"
+        f"start={LOADER2_START}, size={LOADER2_SIZE}, type={LINUX_TYPE}, name=loader2\n"
+        f"start={KERNEL_START}, size={KERNEL_SIZE}, type={LINUX_TYPE}, name=kernel\n"
+        f"start={ROOT_START}, size={root_size}, type={root_type}, name=root\n"
+    )
+    run(["sfdisk", "--quiet", str(out)], input=table)
+    return root_size
+
+
+def maybe_patch_rootfs_modules(rootfs: Path, deb: Path | None) -> None:
+    if deb is None:
+        return
+    with tempfile.TemporaryDirectory(prefix="opencca-kernel-deb.") as tmp:
+        extract_dir = Path(tmp) / "deb"
+        extract_dir.mkdir()
+        run(["dpkg-deb", "-x", str(deb), str(extract_dir)])
+
+        commands = Path(tmp) / "debugfs.cmds"
+        with commands.open("w") as stream:
+            for directory in sorted(p for p in extract_dir.rglob("*") if p.is_dir()):
+                rel = "/" + directory.relative_to(extract_dir).as_posix()
+                if rel in {
+                    "/boot",
+                    "/etc",
+                    "/etc/kernel",
+                    "/etc/kernel/postinst.d",
+                    "/etc/kernel/postrm.d",
+                    "/etc/kernel/preinst.d",
+                    "/etc/kernel/prerm.d",
+                    "/lib",
+                    "/lib/modules",
+                    "/usr",
+                    "/usr/lib",
+                    "/usr/share",
+                    "/usr/share/doc",
+                }:
+                    continue
+                stream.write(f"mkdir {rel}\n")
+            for file_path in sorted(p for p in extract_dir.rglob("*") if p.is_file()):
+                rel = "/" + file_path.relative_to(extract_dir).as_posix()
+                stream.write(f"write {file_path} {rel}\n")
+        run(["debugfs", "-w", "-f", str(commands), str(rootfs)])
+        run(["e2fsck", "-fy", str(rootfs)])
+
+
+def convert_image(args: argparse.Namespace) -> None:
+    source = args.source.resolve()
+    output = args.output.resolve()
+    kernel = args.kernel.resolve()
+
+    if source == output:
+        raise SystemExit("Source and output image paths must differ")
+    if not source.is_file():
+        raise SystemExit(f"Missing source image: {source}")
+    if not kernel.is_file():
+        raise SystemExit(f"Missing kernel image: {kernel}")
+
+    source_sectors = image_sectors(source)
+    kernel_sectors = sectors_for_bytes(kernel.stat().st_size)
+    if kernel_sectors > KERNEL_SIZE:
+        raise SystemExit(
+            f"Kernel image too large: {kernel.stat().st_size} bytes > "
+            f"{KERNEL_SIZE * SECTOR_SIZE} bytes"
+        )
+
+    parts = partition_table(source)
+    loader1 = find_partition(parts, "loader1")
+    loader2 = find_partition(parts, "loader2")
+    root = find_partition(parts, "root")
+
+    if int(root["start"]) >= ROOT_START:
+        raise SystemExit(f"{source} already appears to use the compatible root layout")
+
+    root_type = root.get("type") or EFI_TYPE
+    with tempfile.TemporaryDirectory(prefix="opencca-convert.") as tmp:
+        rootfs = Path(tmp) / "rootfs.ext4"
+        extract_range(source, rootfs, int(root["start"]), int(root["size"]))
+        maybe_patch_rootfs_modules(rootfs, args.linux_image_deb.resolve() if args.linux_image_deb else None)
+        shrink_ext4(rootfs)
+        rootfs_sectors = sectors_for_bytes(rootfs.stat().st_size)
+        output_sectors = max(source_sectors, ROOT_START + rootfs_sectors + 34)
+        root_capacity = output_sectors - ROOT_START - 34
+        if rootfs_sectors > root_capacity:
+            raise SystemExit(
+                f"Rootfs is too large after shrink: {rootfs_sectors} sectors > "
+                f"{root_capacity} sectors"
+            )
+
+        output.parent.mkdir(parents=True, exist_ok=True)
+        shutil.copyfile(source, output)
+        run(["truncate", "-s", str(output_sectors * SECTOR_SIZE), str(output)])
+
+        root_capacity = make_partition_table(output, output_sectors, root_type)
+        copy_range(source, output, int(loader1["start"]), LOADER1_START, int(loader1["size"]))
+        copy_range(source, output, int(loader2["start"]), LOADER2_START, int(loader2["size"]))
+        write_file_to_sector(kernel, output, KERNEL_START)
+        write_file_to_sector(rootfs, output, ROOT_START)
+
+    print(f"Wrote compatible image: {output}")
+    print(f"Kernel slot: start={KERNEL_START:#x}, sectors={KERNEL_SIZE:#x}")
+    print(f"Rootfs: start={ROOT_START:#x}, capacity_sectors={root_capacity:#x}")
+
+
+def main() -> None:
+    for tool in ("sfdisk", "dd", "truncate", "e2fsck", "resize2fs"):
+        require_tool(tool)
+
+    parser = argparse.ArgumentParser(
+        description="Convert an older OpenCCA Rockchip image to the raw-kernel-slot layout"
+    )
+    parser.add_argument("source", type=Path)
+    parser.add_argument("output", type=Path)
+    parser.add_argument("--kernel", type=Path, default=Path("snapshot/kernel.img"))
+    parser.add_argument(
+        "--linux-image-deb",
+        type=Path,
+        help="Optional linux-image .deb to inject into the rootfs before shrinking",
+    )
+    args = parser.parse_args()
+
+    if args.linux_image_deb:
+        for tool in ("debugfs", "dpkg-deb"):
+            require_tool(tool)
+
+    try:
+        convert_image(args)
+    except subprocess.CalledProcessError as exc:
+        print(f"Command failed: {' '.join(exc.cmd)}", file=sys.stderr)
+        raise SystemExit(exc.returncode)
+
+
+if __name__ == "__main__":
+    main()
