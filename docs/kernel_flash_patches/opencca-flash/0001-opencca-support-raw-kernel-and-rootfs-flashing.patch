+++ b/validate_gpt_kernel_slot.py
@@ -0,0 +1,136 @@
+#!/usr/bin/env python3
+import argparse
+import struct
+import sys
+from pathlib import Path
+
+
+SECTOR_SIZE = 512
+GPT_HEADER_LBA = 1
+GPT_SIGNATURE = b"EFI PART"
+PARTITION_NAME_OFFSET = 56
+PARTITION_NAME_SIZE = 72
+MIN_GPT_ENTRY_SIZE = 128
+
+
+def parse_int(value: str) -> int:
+    return int(value, 0)
+
+
+def fail(message: str) -> None:
+    print(message, file=sys.stderr)
+    raise SystemExit(1)
+
+
+def partition_name(entry: bytes) -> str:
+    name = entry[
+        PARTITION_NAME_OFFSET : PARTITION_NAME_OFFSET + PARTITION_NAME_SIZE
+    ]
+    return name.decode("utf-16le", errors="ignore").rstrip("\x00")
+
+
+def validate_named_slot(
+    gpt_path: Path,
+    partition_name_expected: str,
+    expected_start: int,
+    slot_sectors: int,
+    required_bytes: int | None = None,
+) -> None:
+    expected_end = expected_start + slot_sectors - 1
+    data = gpt_path.read_bytes()
+
+    if len(data) < (GPT_HEADER_LBA + 1) * SECTOR_SIZE:
+        fail("GPT read was shorter than the primary header")
+
+    header_offset = GPT_HEADER_LBA * SECTOR_SIZE
+    header = data[header_offset : header_offset + SECTOR_SIZE]
+    if header[:8] != GPT_SIGNATURE:
+        fail("No GPT header found on eMMC")
+
+    entries_lba = struct.unpack_from("<Q", header, 72)[0]
+    entry_count = struct.unpack_from("<I", header, 80)[0]
+    entry_size = struct.unpack_from("<I", header, 84)[0]
+    if entry_size < MIN_GPT_ENTRY_SIZE:
+        fail(f"Unsupported GPT entry size {entry_size}")
+
+    entries_offset = entries_lba * SECTOR_SIZE
+    entries_end = entries_offset + entry_count * entry_size
+    if entries_end > len(data):
+        fail("GPT partition entries extend beyond the read buffer")
+
+    slot_ok = False
+    bad_slot_entries: list[str] = []
+    overlaps: list[str] = []
+
+    for index in range(entry_count):
+        offset = entries_offset + index * entry_size
+        entry = data[offset : offset + entry_size]
+        if len(entry) < MIN_GPT_ENTRY_SIZE or entry[:16] == b"\x00" * 16:
+            continue
+
+        first_lba = struct.unpack_from("<Q", entry, 32)[0]
+        last_lba = struct.unpack_from("<Q", entry, 40)[0]
+        if last_lba < first_lba:
+            continue
+
+        name = partition_name(entry)
+        overlaps_slot = first_lba <= expected_end and last_lba >= expected_start
+
+        if name == partition_name_expected:
+            if first_lba != expected_start:
+                bad_slot_entries.append(f"{name} [{first_lba:#x}-{last_lba:#x}]")
+                continue
+            if required_bytes is not None:
+                available_bytes = (last_lba - first_lba + 1) * SECTOR_SIZE
+                if available_bytes < required_bytes:
+                    fail(
+                        f"{name} partition is too small: {available_bytes} bytes "
+                        f"< {required_bytes} bytes"
+                    )
+            if last_lba >= expected_end:
+                slot_ok = True
+            else:
+                bad_slot_entries.append(f"{name} [{first_lba:#x}-{last_lba:#x}]")
+        elif overlaps_slot:
+            overlaps.append(f"{name or '<unnamed>'} [{first_lba:#x}-{last_lba:#x}]")
+
+    if not slot_ok:
+        detail = f" Found: {', '.join(bad_slot_entries)}." if bad_slot_entries else ""
+        fail(
+            f"Expected GPT {partition_name_expected} partition at {expected_start:#x} "
+            f"covering at least {slot_sectors:#x} sectors.{detail}"
+        )
+
+    if overlaps:
+        fail(
+            f"{partition_name_expected} slot overlaps other partitions: "
+            + ", ".join(overlaps)
+        )
+
+
+def validate_kernel_slot(gpt_path: Path, expected_start: int, slot_sectors: int) -> None:
+    validate_named_slot(gpt_path, "kernel", expected_start, slot_sectors)
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser(
+        description="Validate that an eMMC GPT dump has an OpenCCA partition slot"
+    )
+    parser.add_argument("gpt_dump", type=Path)
+    parser.add_argument("kernel_start", type=parse_int)
+    parser.add_argument("kernel_sectors", type=parse_int)
+    parser.add_argument("--name", default="kernel")
+    parser.add_argument("--required-bytes", type=parse_int)
+    args = parser.parse_args()
+
+    validate_named_slot(
+        args.gpt_dump,
+        args.name,
+        args.kernel_start,
+        args.kernel_sectors,
+        args.required_bytes,
+    )
+
+
+if __name__ == "__main__":
+    main()
