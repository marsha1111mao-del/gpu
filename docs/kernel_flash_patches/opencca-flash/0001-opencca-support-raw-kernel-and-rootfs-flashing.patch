 }
 
+function require_file {
+    local file=$1
+
+    if [[ ! -f "$file" ]]; then
+        echo "Missing required file: $file" >&2
+        exit 1
+    fi
+}
+
+function require_kernel_fits_slot {
+    local max_bytes=$(( FLASH_MMC_KERNEL_MAX_SECTORS * 512 ))
+    local kernel_bytes
+
+    kernel_bytes=$(stat -c%s "$FLASH_MMC_KERNEL")
+    if (( kernel_bytes > max_bytes )); then
+        echo "Kernel image too large: $kernel_bytes bytes > $max_bytes bytes" >&2
+        exit 1
+    fi
+}
+
+function require_mmc_kernel_layout {
+    local gpt_dump
+    local gpt_tmpdir
+
+    gpt_tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/opencca-gpt.XXXXXX")
+    gpt_dump="$gpt_tmpdir/gpt.bin"
+    if ! $CMD rl 0 34 "$gpt_dump"; then
+        rm -rf "$gpt_tmpdir"
+        echo "Failed to read eMMC GPT; refusing to write raw kernel slot" >&2
+        exit 1
+    fi
+
