+#!/usr/bin/env python3
+import argparse
+import struct
+import subprocess
+import sys
+import tempfile
+import uuid
+from pathlib import Path
+
+
+SECTOR_SIZE = 512
+KERNEL_START = 0x8000
+KERNEL_SECTORS = 0x40000
+KERNEL_END = KERNEL_START + KERNEL_SECTORS - 1
+
+
+def add_partition(entry: bytearray, index: int, name: str, first_lba: int, last_lba: int) -> None:
+    offset = 2 * SECTOR_SIZE + index * 128
+    entry[offset : offset + 16] = uuid.UUID("0fc63daf-8483-4772-8e79-3d69d8477de4").bytes_le
+    entry[offset + 16 : offset + 32] = uuid.uuid4().bytes_le
+    struct.pack_into("<Q", entry, offset + 32, first_lba)
+    struct.pack_into("<Q", entry, offset + 40, last_lba)
+    entry[offset + 56 : offset + 128] = name.encode("utf-16le").ljust(72, b"\x00")
+
+
+def make_gpt(partitions: list[tuple[str, int, int]]) -> bytes:
+    data = bytearray(34 * SECTOR_SIZE)
+    header = SECTOR_SIZE
+    data[header : header + 8] = b"EFI PART"
+    struct.pack_into("<Q", data, header + 72, 2)
+    struct.pack_into("<I", data, header + 80, 128)
+    struct.pack_into("<I", data, header + 84, 128)
+
+    for index, (name, first_lba, last_lba) in enumerate(partitions):
+        add_partition(data, index, name, first_lba, last_lba)
+
+    return bytes(data)
+
+
+def run_case(
+    script: Path,
+    image: bytes,
+    expected_code: int,
+    *,
+    start: int = KERNEL_START,
+    sectors: int = KERNEL_SECTORS,
+    extra_args: tuple[str, ...] = (),
+) -> None:
+    with tempfile.NamedTemporaryFile() as gpt:
+        gpt.write(image)
+        gpt.flush()
+        result = subprocess.run(
+            [
+                sys.executable,
+                str(script),
+                gpt.name,
+                hex(start),
+                hex(sectors),
+                *extra_args,
+            ],
+            check=False,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+        )
+    if result.returncode != expected_code:
+        raise AssertionError(
+            f"expected {expected_code}, got {result.returncode}\n"
+            f"stdout:\n{result.stdout}\nstderr:\n{result.stderr}"
+        )
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser()
+    parser.add_argument(
+        "--validator",
+        type=Path,
+        default=Path(__file__).with_name("validate_gpt_kernel_slot.py"),
+    )
+    args = parser.parse_args()
+
+    run_case(
+        args.validator,
+        make_gpt(
+            [
+                ("loader1", 0x40, 0x1C00),
+                ("loader2", 0x4000, 0x5FFF),
+                ("kernel", KERNEL_START, KERNEL_END),
+                ("root", 0x48000, 0x100000),
+            ]
+        ),
+        0,
+    )
+    run_case(
+        args.validator,
+        make_gpt(
+            [
+                ("loader1", 0x40, 0x1C00),
+                ("loader2", 0x4000, 0x5FFF),
+                ("root", KERNEL_START, 0x100000),
+            ]
+        ),
+        1,
+    )
+    run_case(
+        args.validator,
+        make_gpt(
+            [
+                ("loader1", 0x40, 0x1C00),
+                ("loader2", 0x4000, 0x5FFF),
+                ("kernel", 0x9000, KERNEL_END),
+                ("root", 0x48000, 0x100000),
+            ]
+        ),
+        1,
+    )
+    run_case(
+        args.validator,
+        make_gpt(
+            [
+                ("loader1", 0x40, 0x1C00),
+                ("loader2", 0x4000, 0x5FFF),
+                ("kernel", KERNEL_START, KERNEL_END),
+                ("root", 0x48000, 0x100000),
+            ]
+        ),
+        0,
+        start=0x48000,
+        sectors=0x1000,
+        extra_args=("--name", "root", "--required-bytes", "0x100000"),
+    )
+    run_case(
+        args.validator,
+        make_gpt(
+            [
+                ("loader1", 0x40, 0x1C00),
+                ("loader2", 0x4000, 0x5FFF),
+                ("kernel", KERNEL_START, KERNEL_END),
+                ("root", 0x48000, 0x480FF),
+            ]
+        ),
+        1,
+        start=0x48000,
+        sectors=0x1000,
+        extra_args=("--name", "root", "--required-bytes", "0x100000"),
+    )
+    print("GPT slot validation tests passed")
+
+
+if __name__ == "__main__":
+    main()
