+#!/usr/bin/env python3
+import unittest
+from pathlib import Path
+
+
+class FlashScriptTest(unittest.TestCase):
+    def test_gpt_dump_path_is_not_precreated_in_sticky_tmp(self):
+        script = Path(__file__).with_name("flash.sh").read_text()
+
+        self.assertIn('mktemp -d "${TMPDIR:-/tmp}/opencca-gpt.XXXXXX"', script)
+        self.assertIn('gpt_dump="$gpt_tmpdir/gpt.bin"', script)
+
+    def test_mmc_rootfs_command_flashes_rootfs_partition_only(self):
+        script = Path(__file__).with_name("flash.sh").read_text()
+
+        self.assertIn("mmc-rootfs", script)
+        self.assertIn("OPENCCA_ROOTFS_IMAGE", script)
+        self.assertIn("FLASH_MMC_ROOTFS_OFFSET=0x48000", script)
+        self.assertIn("function cmd_flash_mmc_rootfs {", script)
+        self.assertIn('local rootfs_image="${1:-$FLASH_MMC_ROOTFS}"', script)
+        self.assertIn('require_mmc_rootfs_layout "$rootfs_image"', script)
+        self.assertIn('$CMD wl $FLASH_MMC_ROOTFS_OFFSET "$rootfs_image"', script)
+        self.assertIn("mmc-rootfs) cmd_flash_mmc_rootfs", script)
+
+
+if __name__ == "__main__":
+    unittest.main()
