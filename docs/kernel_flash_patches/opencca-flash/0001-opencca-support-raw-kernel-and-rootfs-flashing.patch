+#!/usr/bin/env python3
+import subprocess
+import sys
+import tempfile
+import unittest
+from pathlib import Path
+
+
+SECTOR_SIZE = 512
+KERNEL_START = 0x8000
+ROOT_START = 0x48000
+
+
+class ConvertPrebuiltImageTest(unittest.TestCase):
+    def test_rebuilds_old_layout_with_kernel_partition(self):
+        script = Path(__file__).with_name("convert_prebuilt_image.py")
+
+        with tempfile.TemporaryDirectory() as tmp:
+            tmpdir = Path(tmp)
+            src = tmpdir / "old.img"
+            out = tmpdir / "new.img"
+            rootfs = tmpdir / "root.ext4"
+            kernel = tmpdir / "kernel.img"
+
+            subprocess.run(
+                ["mkfs.ext4", "-q", "-L", "root", "-d", str(tmpdir), str(rootfs), "32M"],
+                check=True,
+            )
+            kernel.write_bytes(b"KERNEL".ljust(1024 * 1024, b"\0"))
+            subprocess.run(["truncate", "-s", str(256 * 1024 * 1024), str(src)], check=True)
+            subprocess.run(
+                [
+                    "sfdisk",
+                    "--quiet",
+                    str(src),
+                ],
+                input=(
+                    "label: gpt\n"
+                    "unit: sectors\n"
+                    "first-lba: 34\n"
+                    "sector-size: 512\n"
+                    "start=64, size=7105, type=linux, name=loader1\n"
+                    "start=16384, size=8192, type=linux, name=loader2\n"
+                    f"start={KERNEL_START}, size={src.stat().st_size // SECTOR_SIZE - KERNEL_START - 34}, type=uefi, name=root\n"
+                ),
+                text=True,
+                check=True,
+            )
+            subprocess.run(
+                ["dd", f"if={rootfs}", f"of={src}", "bs=512", f"seek={KERNEL_START}", "conv=notrunc", "status=none"],
+                check=True,
+            )
+
+            subprocess.run(
+                [
+                    sys.executable,
+                    str(script),
+                    str(src),
+                    str(out),
+                    "--kernel",
+                    str(kernel),
+                ],
+                check=True,
+            )
+
+            table = subprocess.run(
+                ["sfdisk", "-d", str(out)],
+                check=True,
+                stdout=subprocess.PIPE,
+                text=True,
+            ).stdout
+            self.assertIn('start=       32768, size=      262144', table)
+            self.assertIn('name="kernel"', table)
+            self.assertIn('start=      294912', table)
+            self.assertIn('name="root"', table)
+
+            data = out.read_bytes()
+            self.assertEqual(data[KERNEL_START * SECTOR_SIZE : KERNEL_START * SECTOR_SIZE + 6], b"KERNEL")
+            self.assertEqual(data[ROOT_START * SECTOR_SIZE + 0x438 : ROOT_START * SECTOR_SIZE + 0x43A], b"\x53\xef")
+
+    def test_grows_output_when_shifted_rootfs_exceeds_source_size(self):
+        script = Path(__file__).with_name("convert_prebuilt_image.py")
+
+        with tempfile.TemporaryDirectory() as tmp:
+            tmpdir = Path(tmp)
+            src = tmpdir / "old.img"
+            out = tmpdir / "new.img"
+            rootfs = tmpdir / "root.ext4"
+            kernel = tmpdir / "kernel.img"
+
+            subprocess.run(
+                ["mkfs.ext4", "-q", "-L", "root", "-d", str(tmpdir), str(rootfs), "64M"],
+                check=True,
+            )
+            kernel.write_bytes(b"KERNEL".ljust(1024 * 1024, b"\0"))
+            old_root_sectors = rootfs.stat().st_size // SECTOR_SIZE
+            old_image_sectors = KERNEL_START + old_root_sectors + 34
+            subprocess.run(["truncate", "-s", str(old_image_sectors * SECTOR_SIZE), str(src)], check=True)
+            subprocess.run(
+                ["sfdisk", "--quiet", str(src)],
+                input=(
+                    "label: gpt\n"
+                    "unit: sectors\n"
+                    "first-lba: 34\n"
+                    "sector-size: 512\n"
+                    "start=64, size=7105, type=linux, name=loader1\n"
+                    "start=16384, size=8192, type=linux, name=loader2\n"
+                    f"start={KERNEL_START}, size={old_root_sectors}, type=uefi, name=root\n"
+                ),
+                text=True,
+                check=True,
+            )
+            subprocess.run(
+                ["dd", f"if={rootfs}", f"of={src}", "bs=512", f"seek={KERNEL_START}", "conv=notrunc", "status=none"],
+                check=True,
+            )
+
+            subprocess.run(
+                [sys.executable, str(script), str(src), str(out), "--kernel", str(kernel)],
+                check=True,
+            )
+
+            self.assertGreater(out.stat().st_size, src.stat().st_size)
+            table = subprocess.run(
+                ["sfdisk", "-d", str(out)],
+                check=True,
+                stdout=subprocess.PIPE,
+                text=True,
+            ).stdout
+            self.assertIn('start=      294912', table)
+
+
+if __name__ == "__main__":
+    unittest.main()
